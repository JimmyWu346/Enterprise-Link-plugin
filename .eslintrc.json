{
  "root": true,
  "env": {
    "browser": true,
    "es2022": true
  },
  "extends": [
    "eslint:recommended"
  ],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "script"
  },
  "overrides": [
    {
      "files": [
        "local-debug.js"
      ],
      "env": {
        "node": true,
        "browser": false
      }
    }
  ],
  "rules": {
    "no-console": "off"
  }
}
